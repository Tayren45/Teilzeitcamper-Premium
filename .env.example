# Öffentliche URL (Production)
NEXT_PUBLIC_SITE_URL=https://www.teilzeitcamper.ch

# Admin-Zugang — unbedingt ändern!
ADMIN_KEY=teilzeit-admin

# Stripe (TWINT, Karte, Apple/Google Pay, PayPal)
# Dashboard: https://dashboard.stripe.com
# TWINT: Settings → Payment methods → TWINT aktivieren (CHF)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# E-Mail-Benachrichtigungen (Resend: https://resend.com)
NOTIFY_EMAIL=info@teilzeitcamper.ch
NOTIFY_FROM=Teilzeitcamper <noreply@teilzeitcamper.ch>
RESEND_API_KEY=

# Vercel Production — persistente Daten (Pflicht auf Vercel!)
# Upstash Redis: Vercel Dashboard → Storage → Upstash Redis → Connect
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Trip-Clip Medien (Vercel Blob)
# Vercel Dashboard → Storage → Blob → Connect
BLOB_READ_WRITE_TOKEN=
